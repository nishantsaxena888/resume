{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CommonProfile",
  "type": "object",
  "properties": {
    "fullName": { "type": "string" },
    "title": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "phone": { "type": "string" },
    "linkedin": { "type": "string" },
    "location": { "type": "string" }
  },
  "required": ["fullName", "email"]
}
