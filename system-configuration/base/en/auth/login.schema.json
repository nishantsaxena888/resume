{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthLogin",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "title": "Username",
      "description": "Enter Username"
    },
    "password": {
      "type": "string",
      "format": "password",
      "title": "Password",
      "description": "Enter Password"
    }
  },
  "required": ["username", "password"]
}
