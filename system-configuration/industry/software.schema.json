{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SoftwareIndustry",
  "type": "object",
  "properties": {
    "software__summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "software__skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "items": { "type": "string" }
        },
        "required": ["category", "items"]
      }
    },
    "software__experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company": { "type": "string" },
          "role": { "type": "string" },
          "dates": { "type": "string" },
          "points": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["company", "role", "dates", "points"]
      }
    },
    "software__projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "technologies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "description"]
      }
    }
  }
}
